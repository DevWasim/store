<section id="wellness-benefits" class="wellness-benefits" aria-label="Product Benefits">
  <div class="wellness-benefits__grid">
    {%- for block in section.blocks -%}
      <div class="wellness-benefits__item" {{ block.shopify_attributes }}>
        <div class="wellness-benefits__icon">
          {%- if block.settings.icon == 'fast' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          {%- elsif block.settings.icon == 'discreet' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v2h20V6a2 2 0 0 0-2-2zM2 10v8a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-8H2zm6 6H5v-2h3v2z"/></svg>
          {%- elsif block.settings.icon == 'science' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 2v6.5L4.1 18.4A2 2 0 0 0 5.8 21h12.4a2 2 0 0 0 1.7-2.6L15 8.5V2H9zm2 2h2v5.2l1.5 3H9.5L11 9.2V4z"/></svg>
          {%- else -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          {%- endif -%}
        </div>
        <h3 class="wellness-benefits__title">{{ block.settings.title }}</h3>
        <p class="wellness-benefits__text">{{ block.settings.description }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Wellness Benefits",
  "tag": "section",
  "class": "wellness-benefits-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Why Choose Our Products"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "fast", "label": "Fast Acting" },
            { "value": "discreet", "label": "Discreet" },
            { "value": "science", "label": "Science" },
            { "value": "default", "label": "Default" }
          ],
          "default": "default"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this benefit to your customers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wellness Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "fast",
            "title": "Fast Acting Results",
            "description": "Experience noticeable effects within 15 minutes of application. Our advanced transdermal formula delivers active ingredients directly where they're needed most."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "discreet",
            "title": "Discreet Packaging",
            "description": "Your privacy matters. Every order ships in plain, unmarked packaging with no indication of the contents inside. Complete confidentiality guaranteed."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "science",
            "title": "Science-Backed Formulation",
            "description": "Developed in partnership with leading researchers and backed by clinical studies. Every ingredient is selected for proven efficacy and safety."
          }
        }
      ]
    }
  ]
}
{% endschema %}
