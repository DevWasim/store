<section id="duab-benefits" class="duab-benefits" aria-label="Product Benefits">
  <div class="duab-benefits__header">
    <span class="duab-benefits__label">Why Choose Us</span>
    <h2 class="duab-benefits__title">Built for Performance</h2>
    <span class="duab-benefits__accent"></span>
  </div>

  <div class="duab-benefits__grid">
    <div class="duab-benefits__card">
      <div class="duab-benefits__icon">⚡</div>
      <div class="duab-benefits__card-title">Fast Acting</div>
      <p class="duab-benefits__card-desc">Begins working within 15 minutes of application for reliable on-demand performance</p>
    </div>
    <div class="duab-benefits__card">
      <div class="duab-benefits__icon">⏱</div>
      <div class="duab-benefits__card-title">6 Hour Duration</div>
      <p class="duab-benefits__card-desc">Metro Cream maintains peak effectiveness for up to 6 hours with no reapplication needed</p>
    </div>
    <div class="duab-benefits__card">
      <div class="duab-benefits__icon">📦</div>
      <div class="duab-benefits__card-title">Discreet Delivery</div>
      <p class="duab-benefits__card-desc">Plain packaging with no product names printed outside because your privacy is our top priority</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DUAB Benefits",
  "tag": "section",
  "class": "duab-benefits-section",
  "settings": [],
  "presets": [
    {
      "name": "DUAB Benefits"
    }
  ]
}
{% endschema %}
