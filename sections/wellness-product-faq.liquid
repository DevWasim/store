<section id="wellness-faq" class="wellness-faq" aria-label="Frequently Asked Questions">
  <div class="wellness-container">
    <div class="wellness-faq__heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="wellness-faq__list">
      {%- for block in section.blocks -%}
        <details class="wellness-faq__item" {{ block.shopify_attributes }}>
          <summary class="wellness-faq__question">
            <span>{{ block.settings.question }}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <div class="wellness-faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "wellness-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How does this product work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Our product uses a carefully formulated topical solution that is applied directly to the desired area for targeted results.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How long does Metro cream take to work?",
            "answer": "<p>Metro cream is designed for rapid absorption. Most users report noticeable effects within 15 minutes of application. The effects can last for up to 6 hours, providing extended confidence and performance.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is this product safe to use?",
            "answer": "<p>Yes. All our products are clinically tested and formulated with safe, dermatologist-approved ingredients. We recommend reviewing the full ingredient list and consulting your healthcare provider if you have specific medical conditions or concerns.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Are there any side effects?",
            "answer": "<p>Our formulations are designed to minimize side effects. Some users may experience a mild warming or cooling sensation upon application, which is normal and temporary. Discontinue use if any irritation occurs and consult a healthcare professional.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How should I apply the cream?",
            "answer": "<p>Apply a small amount (approximately pea-sized) to the desired area 15 to 20 minutes before desired effect. Gently massage until fully absorbed. Do not exceed the recommended amount. Wash hands after application.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is the packaging discreet?",
            "answer": "<p>Absolutely. We understand the importance of privacy. All orders are shipped in plain, unmarked packaging with no branding or product descriptions visible on the exterior. Your bank statement will show a generic business name.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day money-back guarantee. If you are not completely satisfied with your purchase, contact our customer support team within 30 days for a full refund. No questions asked.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
