{{ 'custom-wellness.css' | asset_url | stylesheet_tag }}

<style>
  .template-wellness-404 {
    background-color: var(--duab-bg);
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 20px;
  }
  .template-wellness-404__image {
    max-width: 400px;
    width: 100%;
    margin: 0 auto 40px;
    border-radius: var(--duab-radius-card);
    border: 1px solid var(--duab-border);
  }
  .template-wellness-404__number {
    font-family: var(--duab-font-heading);
    font-size: 100px;
    font-weight: 800;
    color: var(--duab-emerald);
    line-height: 1;
    margin: 0 0 10px 0;
  }
  .template-wellness-404__heading {
    font-family: var(--duab-font-heading);
    font-size: 24px;
    color: var(--duab-white);
    margin: 0 0 20px 0;
  }
  .template-wellness-404__desc {
    font-family: var(--duab-font-body);
    font-size: 16px;
    color: var(--duab-grey);
    margin: 0 0 40px 0;
    max-width: 500px;
  }
</style>

<div class="template-wellness-404">
  
  <h1 class="template-wellness-404__number">404</h1>
  <h2 class="template-wellness-404__heading">Page Not Found</h2>
  <p class="template-wellness-404__desc">
    The path you are looking for has been moved or no longer exists. Let's get you back on track.
  </p>
  
  <a href="{{ routes.all_products_collection_url }}" class="button">
    Return to Store
  </a>
</div>

{% schema %}
{
  "name": "t:names.404"
}
{% endschema %}
